PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/portfolio

# Gmail SMTP (App Password required)
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-16-character-app-password
ADMIN_EMAIL=your-gmail@gmail.com

# Hidden admin password
ADMIN_PASSWORD=change-this-password

# Session secret for express-session
SESSION_SECRET=super-secret-session-key

# Comma-separated list of frontend URLs allowed by CORS (Vercel domains)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-frontend.vercel.app

# Optional single frontend URL (used if ALLOWED_ORIGINS is not set)
FRONTEND_URL=https://your-frontend.vercel.app

# Optional absolute/relative resume file path
RESUME_FILE_PATH=data/resume.txt
